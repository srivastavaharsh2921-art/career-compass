PORT=5000
TOKEN_SECRET=change-this-local-secret

# Optional. If omitted or unavailable, the backend uses backend/data/db.json.
# MONGO_URI=mongodb+srv://user:password@example.mongodb.net/career-compass
# MONGO_COLLECTION=career_compass

# Required in production for forgot-password emails. Create the key and verify
# the sender/domain in Resend, then set these values in the hosting environment.
# RESEND_API_KEY=re_...
# RESET_EMAIL_FROM=Career Compass <support@your-domain.com>
# APP_URL=https://your-career-compass-domain.com

# Alternative: send reset codes through Gmail. Turn on 2-Step Verification for
# the Gmail account and create an App Password (do not use the normal password).
# GMAIL_USER=your-account@gmail.com
# GMAIL_APP_PASSWORD=your-16-character-app-password
# RESET_EMAIL_FROM=Career Compass <your-account@gmail.com>
# APP_URL=https://your-career-compass-domain.com

# Any SMTP provider can be used instead of the Gmail aliases above.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=mailer@example.com
# SMTP_PASS=your-smtp-password
